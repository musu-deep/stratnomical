# انسخ هذا الملف إلى .env ثم أضف مفتاحك الحقيقي محلياً فقط.
# لا ترفع ملف .env إلى GitHub.
GEMINI_API_KEY=replace_with_your_gemini_api_key

# النموذج الافتراضي المستخدم في المستشار الكوني.
GEMINI_MODEL=gemini-3.5-flash

# المنفذ المحلي. منصات الاستضافة تضبط PORT تلقائياً عادةً.
PORT=3000

# اختياري: الرابط العام بعد النشر.
APP_URL=http://localhost:3000
